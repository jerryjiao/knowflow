# KnowFlow 配置文件
# 复制为 .knowflowrc 后修改

ai:
  provider: "zhipu"  # zhipu | openai | anthropic
  api_key: "your-api-key-here"
  
paths:
  data_dir: "./wiki"
  raw_dir: "./raw"
  graph_output: "./graph/graph.html"

ingest:
  max_file_size_mb: 10
  supported_sources:
    - twitter
    - web
    - wechat
    - xiaohongshu
    - youtube
    
graph:
  max_nodes: 500
  auto_open: true
  
query:
  top_k: 5
  hybrid_search: true
